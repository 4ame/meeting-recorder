# Copier ce fichier en .env et renseigner les valeurs
# Ne jamais committer .env dans git

# Clé API Google Gemini
# Obtenir sur : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Dossiers (optionnel — valeurs par défaut dans le code)
# RECORDINGS_DIR=C:/Users/VotreNom/Documents/GeneratedCR/Recordings
# OUTPUT_DIR=C:/Users/VotreNom/Documents/GeneratedCR/CompteRendus

# Modèle Whisper : tiny | base | small | medium | large-v3-turbo | large-v3
# Recommandé : large-v3-turbo (meilleur compromis vitesse/qualité sur GPU)
WHISPER_MODEL=large-v3-turbo

# WhisperX — transcription avec alignement mot à mot et diarisation
# Mettre à 1 pour activer WhisperX (nécessite venv-whisperx, Python 3.12, ffmpeg)
# Mettre à 0 pour utiliser Whisper vanilla
USE_WHISPERX=0

# Token HuggingFace (optionnel) — active la diarisation speaker dans WhisperX
# 1. Créer un compte sur https://huggingface.co
# 2. Accepter les CGU sur https://huggingface.co/pyannote/speaker-diarization-3.1
# 3. Générer un token sur https://huggingface.co/settings/tokens
HF_TOKEN=
