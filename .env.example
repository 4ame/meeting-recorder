# Copier ce fichier en .env et renseigner les valeurs
# Ne jamais committer .env dans git

# Clé API Google Gemini
# Obtenir sur : https://console.cloud.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Dossiers (optionnel — valeurs par défaut dans le code)
# RECORDINGS_DIR=C:/Users/VotreNom/Documents/GeneratedCR/Recordings
# OUTPUT_DIR=C:/Users/VotreNom/Documents/GeneratedCR/CompteRendus

# Modèle Whisper : tiny | base | small | medium | large
# Recommandé : small (bon compromis vitesse/qualité)
WHISPER_MODEL=small
